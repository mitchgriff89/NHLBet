// ─── SEND ONE GAME ────────────────────────────────────────────
async function sendGame(game, index, total) {
  const odds = generateOdds(game.baseHomeWinPct);
  const sim = runMonteCarlo(game);
  const bet = getBestBet(game, odds, sim);
  const msg = buildMessage(game, odds, sim, bet, index, total);

  try {
    await bot.sendMessage(CHAT_ID, msg, { parse_mode: "HTML" });
    console.log(`✅ Sent: ${game.awayAbbr} @ ${game.homeAbbr}`);
  } catch (e) {
    console.error(`❌ Failed to send ${game.awayAbbr} @ ${game.homeAbbr}:`, e.message);
  }

  // Delay between messages to avoid Telegram rate limits
  await new Promise((r) => setTimeout(r, 2000));
}

// ─── SEND DAILY DIGEST ───────────────────────────────────────
async function sendDailyDigest() {
  console.log("📡 Running daily NHL playoff digest...");

  // Try live schedule first
  let games = await fetchNHLSchedule();

  if (!games || games.length === 0) {
    console.log("Using fallback game data...");
    games = getFallbackGames();
  }

  if (games.length === 0) {
    await bot.sendMessage(
      CHAT_ID,
      "🏒 <b>NHL BETTING BOT</b>\n\nNo playoff games scheduled today. Check back tomorrow!",
      { parse_mode: "HTML" }
    );
    return;
  }

  // Header message
  await bot.sendMessage(
    CHAT_ID,
    `🏒 <b>NHL PLAYOFF DAILY ALERT</b>\n📅 ${new Date().toLocaleDateString("en-CA", { weekday: "long", month: "long", day: "numeric", timeZone: "America/Toronto" })}\n\n🎮 <b>${games.length} games today</b>\nSending full analysis now...`,
    { parse_mode: "HTML" }
  );

  await new Promise((r) => setTimeout(r, 1500));

  // Send each game
  for (let i = 0; i < games.length; i++) {
    await sendGame(games[i], i + 1, games.length);
  }

  console.log(`✅ Digest complete — ${games.length} games sent`);
}

// ─── SCHEDULE ─────────────────────────────────────────────────
// Runs at 2:00 PM Eastern (19:00 UTC) every day
// Change the cron string to adjust timing:
//   "0 17 * * *"  = 12 PM EST (5 PM UTC)
//   "0 19 * * *"  = 2 PM EST (7 PM UTC)  ← default
//   "0 21 * * *"  = 4 PM EST (9 PM UTC)
cron.schedule("0 19 * * *", () => {
  sendDailyDigest();
}, {
