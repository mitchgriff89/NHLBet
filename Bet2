// ─── GENERATE SYNTHETIC ODDS (8 books) ───────────────────────
function generateOdds(baseHomeWinPct) {
  const books = {};
  BOOKMAKERS.forEach((bk) => {
    const noise = (Math.random() - 0.5) * 5;
    const homeProb = Math.min(Math.max(baseHomeWinPct + noise, 28), 76);
    const awayProb = 100 - homeProb;

    const toML = (prob) => {
      if (prob >= 50) {
        return `-${Math.round((prob / (100 - prob)) * 100)}`;
      } else {
        return `+${Math.round(((100 - prob) / prob) * 100)}`;
      }
    };

    const totalNoise = (Math.random() - 0.5) * 0.5;
    books[bk] = {
      homeML: toML(homeProb),
      awayML: toML(awayProb),
      total: (5.5 + totalNoise).toFixed(1),
      homeProb: homeProb.toFixed(1),
    };
  });
  return books;
}

// ─── MONTE CARLO — 10 SIMULATIONS ────────────────────────────
function runMonteCarlo(game, runs = 10) {
  const baseHome = game.baseHomeWinPct / 100;

  // Injury adjustment
  const homeOutCount = game.injuries.home.filter((i) =>
    i.includes("OUT")
  ).length;
  const homeGTDCount = game.injuries.home.filter((i) =>
    i.includes("GTD")
  ).length;
  const awayOutCount = game.injuries.away.filter((i) =>
    i.includes("OUT")
  ).length;
  const awayGTDCount = game.injuries.away.filter((i) =>
    i.includes("GTD")
  ).length;

  const adjustedHome = Math.min(
    Math.max(
      baseHome -
        homeOutCount * 0.03 -
        homeGTDCount * 0.015 +
        awayOutCount * 0.03 +
        awayGTDCount * 0.015,
      0.2
    ),
    0.8
  );

  const results = [];
  for (let i = 0; i < runs; i++) {
    const homeWins = Math.random() < adjustedHome;
    const baseGoals = Math.round(2 + Math.random() * 3);
    const otherGoals = Math.round(1 + Math.random() * 3);
    const homeScore = homeWins
      ? Math.max(baseGoals, otherGoals + 1)
      : Math.min(baseGoals, otherGoals - 1);
    const awayScore = homeWins
      ? Math.min(otherGoals, baseGoals - 1)
      : Math.max(otherGoals, baseGoals + 1);
    const ot = Math.random() < 0.22;
    results.push({
      run: i + 1,
      winner: homeWins ? game.homeAbbr : game.awayAbbr,
      homeScore,
      awayScore,
      ot,
    });
  }

  const homeWins = results.filter((r) => r.winner === game.homeAbbr).length;
  const totalGoals = results.reduce(
    (s, r) => s + r.homeScore + r.awayScore,
    0
  );
  const otGames = results.filter((r) => r.ot).length;

  return {
    results,
    homeWinPct: ((homeWins / runs) * 100).toFixed(0),
    awayWinPct: (((runs - homeWins) / runs) * 100).toFixed(0),
    avgTotal: (totalGoals / runs).toFixed(1),
    otPct: ((otGames / runs) * 100).toFixed(0),
    adjustedHomeProb: (adjustedHome * 100).toFixed(1),
  };
}

// ─── BEST BET ENGINE ─────────────────────────────────────────
function getBestBet(game, odds, sim) {
  const homeProb = parseFloat(sim.homeWinPct) / 100;
  let bestBet = { edge: -99 };

  for (const [bk, o] of Object.entries(odds)) {
    // Home ML edge
    const homeML = parseInt(o.homeML);
    const homeImplied =
      homeML < 0
        ? Math.abs(homeML) / (Math.abs(homeML) + 100)
        : 100 / (homeML + 100);
    const homeEdge = homeProb - homeImplied;

    if (homeEdge > bestBet.edge) {
      bestBet = {
        edge: homeEdge,
        book: bk,
        ml: o.homeML,
        team: game.homeAbbr,
        fullTeam: game.home,
        side: "home",
      };
    }

    // Away ML edge
    const awayML = parseInt(o.awayML);
    const awayImplied =
      awayML < 0
        ? Math.abs(awayML) / (Math.abs(awayML) + 100)
        : 100 / (awayML + 100);
    const awayEdge = 1 - homeProb - awayImplied;

    if (awayEdge > bestBet.edge) {
      bestBet = {
        edge: awayEdge,
        book: bk,
        ml: o.awayML,
        team: game.awayAbbr,
        fullTeam: game.away,
        side: "away",
      };
    }
  }

  const avgTotal = parseFloat(sim.avgTotal);
  const overUnder = avgTotal > 5.5 ? "OVER 5.5" : "UNDER 5.5";
  const roi = (bestBet.edge * 100).toFixed(1);
  const confidence =
    parseFloat(roi) >= 6
      ? "🔥 HIGH"
      : parseFloat(roi) >= 3
      ? "⚡ MEDIUM"
      : "❄️ LOW";

  return { ...bestBet, overUnder, roi, confidence };
}

// ─── BUILD TELEGRAM MESSAGE ───────────────────────────────────
function buildMessage(game, odds, sim, bet, gameIndex, totalGames) {
  const date = new Date().toLocaleDateString("en-CA", {
    weekday: "long",
    month: "short",
    day: "numeric",
    year: "numeric",
    timeZone: "America/Toronto",
  });

  // Odds table
  const oddsLines = BOOKMAKERS.map((bk) => {
    const o = odds[bk];
    const homeFlag = o.homeML.startsWith("-") ? "🟢" : "🔴";
    const awayFlag = o.awayML.startsWith("-") ? "🟢" : "🔴";
    return `${bk.padEnd(11)} ${homeFlag}${game.homeAbbr} ${o.homeML.padStart(5)}  ${awayFlag}${game.awayAbbr} ${o.awayML.padStart(5)}  O/U ${o.total}`;
  }).join("\n");

  // Sim results
  const simLines = sim.results
    .map((r) => {
      const winnerEmoji = r.winner === game.homeAbbr ? "🏠" : "✈️";
      return `  Run ${r.run}: ${game.homeAbbr} ${r.homeScore}-${r.awayScore} ${game.awayAbbr}  ${winnerEmoji}${r.winner}${r.ot ? " OT" : ""}`;
    })
    .join("\n");

  // Injury lines
  const homeInjuries = game.injuries.home
    .map((i) => {
      const icon = i.includes("OUT") ? "🔴" : i.includes("GTD") ? "🟡" : "🟢";
      return `  ${icon} ${i}`;
    })
    .join("\n");

  const awayInjuries = game.injuries.away
    .map((i) => {
      const icon = i.includes("OUT") ? "🔴" : i.includes("GTD") ? "🟡" : "🟢";
      return `  ${icon} ${i}`;
    })
    .join("\n");

  return `🏒 <b>NHL PLAYOFF BETTING INTEL</b> [${gameIndex}/${totalGames}]
📅 ${date}
━━━━━━━━━━━━━━━━━━━━━━
<b>⚔️ ${game.awayAbbr} @ ${game.homeAbbr}</b>
${game.away} vs ${game.home}
📊 ${game.series} | ${game.seriesRecord}
━━━━━━━━━━━━━━━━━━━━━━

📈 <b>8-BOOK ODDS</b>
<code>${oddsLines}</code>

━━━━━━━━━━━━━━━━━━━━━━
🎲 <b>MONTE CARLO — 10 SIMULATIONS</b>
<code>${simLines}</code>

📊 <b>SIMULATION RESULTS</b>
  🏠 ${game.homeAbbr} Win: <b>${sim.homeWinPct}%</b> (${sim.adjustedHomeProb}% adj)
  ✈️ ${game.awayAbbr} Win: <b>${sim.awayWinPct}%</b>
