// Uses the free SportRadar-backed odds API via the-odds-api.com
// Sign up free at the-odds-api.com and add ODDS_API_KEY to Railway env vars
async function fetchLiveOdds() {
  const ODDS_API_KEY = process.env.ODDS_API_KEY;

  if (!ODDS_API_KEY) {
    console.log("⚠️  No ODDS_API_KEY set — using simulated odds");
    return null;
  }

  try {
    const res = await axios.get(
      "https://api.the-odds-api.com/v4/sports/icehockey_nhl/odds",
      {
        params: {
          apiKey: ODDS_API_KEY,
          regions: "us",
          markets: "h2h,totals",
          oddsFormat: "american",
        },
        timeout: 10000,
      }
    );
    return res.data;
  } catch (e) {
    console.log("⚠️  Odds API error:", e.message, "— using simulated odds");
    return null;
  }
}

// ─── FETCH NHL SCORES / SCHEDULE ─────────────────────────────
async function fetchNHLSchedule() {
  try {
    // NHL free schedule API
    const today = new Date().toISOString().split("T")[0];
    const res = await axios.get(
      `https://api-web.nhle.com/v1/schedule/${today}`,
      { timeout: 10000 }
    );
    const gameWeek = res.data?.gameWeek || [];
    const games = [];
    for (const day of gameWeek) {
      for (const g of day.games || []) {
        if (g.gameType === 3) {
          // 3 = playoffs
          games.push({
            id: g.id,
            home: g.homeTeam?.commonName?.default || g.homeTeam?.abbrev,
            homeAbbr: g.homeTeam?.abbrev,
            away: g.awayTeam?.commonName?.default || g.awayTeam?.abbrev,
            awayAbbr: g.awayTeam?.abbrev,
            time: g.startTimeUTC,
            gameType: g.gameType,
            seriesStatus: g.seriesStatus,
          });
        }
      }
    }
    return games.length > 0 ? games : null;
  } catch (e) {
    console.log("⚠️  NHL API error:", e.message, "— using fallback data");
    return null;
  }
}

